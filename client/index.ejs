<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DHTMLX Scheduler with Google Calendar</title>
  <link rel="stylesheet" href="/build/main.css" />
  <script>
    const GOOGLE_AUTHORIZED = <%= !!googleAuth %>;
  </script>
  <style>

  </style>
</head>

<body>
  <header>
    <h1>DHTMLX Scheduler with Google Calendar</h1>
    <div class="controls">
      <% if (!googleAuth) { %>
        <a href="/auth/google">Add Google Calendars</a>
        <% } else { %>
          <a href="/auth/google/logout">Clear session</a>
          <a href="https://calendar.google.com/calendar">Check Google Calendar</a>
          <% } %>
    </div>
  </header>
  <section class="main">
    <div id="scheduler_here" class="dhx_cal_container" style='width:100%; height:100%;'></div>
  </section>
  <script src="/build/main.js" defer></script>
</body>