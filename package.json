  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "npm run start:dev",
    "build": "rollup -c rollup.config.js && tsc -p tsconfig.server.json",
    "start:prod": "npm run build && node dist/server/index.js",
    "start:dev": "concurrently \"npm run watch:rollup\" \"npm run watch:server\"",
    "watch:rollup": "rollup -c rollup.config.js --watch",
    "watch:server": "tsx watch server/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
