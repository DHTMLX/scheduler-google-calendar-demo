    "@rollup/plugin-node-resolve": "^16.0.3",
    "concurrently": "^9.2.1",
    "dotenv-flow": "^4.1.0",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "googleapis": "^170.0.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "postcss": "^8.5.6",
